# Server
PORT=3000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGODB_DB=gymos

# Auth
AUTH_JWT_SECRET=replace-with-your-auth-jwt-secret
SESSION_JWT_SECRET=replace-with-your-session-secret
OWNER_AUTH_ID=
DEV_LOGIN_EMAIL=
DEV_LOGIN_NAME=
DEV_LOGIN_ROLE=admin

# Platform APIs (optional unless you use AI/voice/image/storage/notification features)
PLATFORM_API_URL=
PLATFORM_API_KEY=

# RapidAPI integrations (ExerciseDB + YouTube search)
RAPIDAPI_KEY=
EXERCISEDB_API_HOST=exercisedb.p.rapidapi.com
YOUTUBE_SEARCH_API_HOST=youtube-search-and-download.p.rapidapi.com

# Free exercise catalog (no subscription required)
FREE_EXERCISE_DB_URL=https://raw.githubusercontent.com/yuhonas/free-exercise-db/main/dist/exercises.json
FREE_EXERCISE_IMAGE_BASE_URL=https://raw.githubusercontent.com/yuhonas/free-exercise-db/main/exercises/

# Maps
GOOGLE_MAPS_API_KEY=
MAPS_PROXY_URL=

# Telegram campaign delivery
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# Email campaign delivery (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# SaaS REST API (Main platform DB + isolated Mongo tenant DBs)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gymos_saas?schema=public
SAAS_MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
SAAS_PLATFORM_DB=gymos_platform
SAAS_TENANT_DB_PREFIX=gymos
SAAS_PORT=4000
SAAS_CORS_ORIGIN=*
APP_BASE_DOMAIN=platform.com
JWT_ACCESS_SECRET=replace-with-access-secret
JWT_REFRESH_SECRET=replace-with-refresh-secret
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=30
BCRYPT_ROUNDS=10
TRIAL_DAYS=30
BASIC_MEMBER_LIMIT=100

# Client (Vite)
VITE_AUTH_LOGIN_URL=http://localhost:3000/local-login
VITE_GOOGLE_MAPS_API_KEY=
VITE_MAPS_PROXY_URL=

# Optional analytics vars used by client/index.html
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
